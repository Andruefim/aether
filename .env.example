# Server (NestJS) port. Client Vite proxies /api to this port.
PORT=3001

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=aether

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35b-a3b
AETHER_ORCHESTRATOR_MODEL=qwen3.5:35b-a3b
AETHER_CODER_MODEL=qwen3.5:35b-a3b

NOVA_MAIN_MODEL=qwen3.5:35b-a3b
NOVA_FAST_MODEL=gemma3:12b-it-qat

LAB_MODEL=gemma3:12b-it-qat

OLLAMA_API_KEY=

NOVA_LORA_BASE_MODEL=gemma3:12b
NOVA_LORA_DATA_DIR=./nova-lora/data
NOVA_LORA_ADAPTER_DIR=./nova-lora/adapters
NOVA_LORA_TRAINER=./nova-lora/trainer.py
# After first successful training:
# NOVA_MAIN_MODEL=nova-tuned:latest


# Get one at [console.cloud.google.com](https://console.cloud.google.com) → Enable **YouTube Data API v3** → Create an API key.
YOUTUBE_API_KEY=


# ── Qdrant (memory / constellation) ───────────────────────────
QDRANT_URL=http://localhost:6333

# ── Nova Lab (Python sandbox) ────────────────────────────────────
# Start with: cd server/sandbox && pip install -r requirements.txt && python main.py
SANDBOX_URL=http://localhost:5050


# ── Aether Voice Service ────────────────────────────────────────
VOICE_SERVICE_URL=http://localhost:8001
WHISPER_MODEL=large-v3-turbo
DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
REFERENCE_WAV=assets/reference.wav
